programa {
  funcao inicio() {
    inteiro chamada_1
    inteiro chamada_2
    inteiro chamada_3
    inteiro total

    escreva("Digite o tempo da 1° ligação: ")
    leia(chamada_1)
    escreva("Digite o tempo da 2° ligação: ")
    leia(chamada_2)
    escreva("Digite o tempo da 3° ligação: ")
    leia(chamada_3)

    total = chamada_1 + chamada_2 + chamada_3

    escreva("O tempo total das ligações é: ", total)
  }
}
